---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home.css";
---

<BaseLayout bodyClass="overlay-header" title="Nuus" description="Nuus — creative group." current="home">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-video" role="region" aria-label="Intro video banner">
        <!-- Desktop video -->
        <video 
          id="heroVideo"
          class="hero-media hero-media-desktop" 
          autoplay 
          muted 
          playsinline 
          preload="auto"
          webkit-playsinline
        >
          <source src="/assets/home/home-video.mp4" type="video/mp4" />
        </video>

        <!-- Mobile hero stack -->
        <div class="mobile-hero-media">
          <img 
            src="/assets/home/hero-image-mobile.webp" 
            alt="Hero top"
            class="hero-media hero-media-mobile hero-media-bw"
            loading="eager"
            fetchpriority="high"
          />
          
          <img 
            src="/assets/home/home-video-mobile.gif" 
            alt="Hero animation"
            class="hero-media hero-media-mobile"
            loading="eager"
          />
          
          <img 
            src="/assets/home/hero-image-mobile.webp" 
            alt="Hero bottom"
            class="hero-media hero-media-mobile hero-media-bw"
            loading="lazy"
          />
        </div>

        <div class="mobile-hero-frame" aria-hidden="true"></div>

        <nav class="mobile-hero-nav" aria-label="Primary navigation (mobile hero)">
          <a class="mobile-hero-nav-item" href="/what">具現化したアイデア</a>
          <a class="mobile-hero-nav-item" href="/who">脳</a>
          <a class="mobile-hero-nav-item" href="/when">今考えてること</a>
        </nav>

        <div
          class="glitch-stage glitch-stage--hero"
          id="glitchStageHero"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </section>

  <section class="alien-section">
    <div class="container">
      <div class="alien-grid" id="alienGrid" aria-label="Alien language images">
        <figure class="alien-item">
          <img
            src="/assets/home/alien_languages_png/alien_languages1.png"
            alt="Alien language 1"
            loading="lazy"
          />
          <figcaption class="alien-meta">Meta text for 1</figcaption>
        </figure>

