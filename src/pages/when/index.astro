---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/when.css";
---

<BaseLayout
  title="When — Nuus"
  description="Project collection"
  current="when"
>

      <div class="container">
        <div class="mono-card">
          <h1 style="font-size: var(--h2); margin-bottom: 10px">When</h1>
          <p class="lede">
            A simple timeline + availability. Keep this short and scannable.
          </p>

          <div class="kv">
            <div class="item">
              <h3 style="font-size: 14px; margin-bottom: 6px">Now</h3>
              <p>
                Open to freelance / collaborations. Based in Amsterdam / NL.
              </p>
            </div>
            <div class="item">
              <h3 style="font-size: 14px; margin-bottom: 6px">2025–2026</h3>
              <p>
                Major focus: shipping polished web + interaction projects,
                portfolio consolidation.
              </p>
            </div>
            <div class="item">
              <h3 style="font-size: 14px; margin-bottom: 6px">Earlier</h3>
              <p>
                Experimental work exploring body + tech, gestures, control, and
                play.
              </p>
            </div>
          </div>
        </div>
      </div>
</BaseLayout>

 

   