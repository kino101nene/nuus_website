---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  loading?: 'lazy' | 'eager';
  class?: string;
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { src, alt, loading = 'lazy', class: className, fetchpriority } = Astro.props;
---

<Image src={src} alt={alt} loading={loading} class={className} fetchpriority={fetchpriority} />
