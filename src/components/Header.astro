---

const { pathname } = Astro.url;

const isWhat = pathname === "/what" || pathname.startsWith("/what/");
const isWhen = pathname === "/when" || pathname.startsWith("/when/");
const isWho  = pathname === "/who"  || pathname.startsWith("/who/");
---

 <header class="site-header">
   <div class="header-inner">
<a href="/" class="logo-link" aria-label="Go to home">
  <img
    class="logo"
    src="/assets/header/nuus_logo_bl.svg"
    alt="Nuus logo"
    width="180"
    height="34"
    loading="eager"
    fetchpriority="high"
  />
</a>


<nav class="nav" aria-label="Primary">
  <a class="nav-item" href="/what" aria-current={isWhat ? "page" : undefined}>
    具現化したアイデア
  </a>
  <a class="nav-item" href="/who" aria-current={isWho ? "page" : undefined}>
    脳
  </a>
  <a class="nav-item" href="/when" aria-current={isWhen ? "page" : undefined}>
    今考えてること
  </a>
</nav>

<div class="header-right">
  <div class="contact-links" aria-label="Contact links">
    <!-- Email -->
    <a
      class="icons"
      href="mailto:you@example.com"
      aria-label="Email"
    >
